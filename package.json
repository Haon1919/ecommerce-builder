{
  "name": "ecommerce-builder",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:ui": "playwright test",
    "test:perf:local": "docker run --rm -i -v \"$(pwd)/tests/performance/scenarios:/tests/scenarios\" grafana/k6 run /tests/scenarios/storefront-load.js",
    "test:security": "./scripts/security-audit.sh",
    "db:migrate": "npm run db:migrate --workspace=services/api",
    "db:seed": "npm run db:seed --workspace=services/api"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "turbo": "^2.8.14"
  }
}