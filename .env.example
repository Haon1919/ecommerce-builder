# ============================================
# ECOMMERCE BUILDER - ENVIRONMENT VARIABLES
# Copy this to .env and fill in the values
# ============================================

# --- Database ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ecommerce_builder"

# --- Authentication ---
# Generate with: openssl rand -base64 48
JWT_SECRET=""
JWT_EXPIRES_IN="7d"
# Generate with: openssl rand -base64 48
REFRESH_TOKEN_SECRET=""
REFRESH_TOKEN_EXPIRES_IN="30d"

# --- Encryption (for PII data at rest) ---
# Must be exactly 32 chars for AES-256. Generate with: openssl rand -hex 16
ENCRYPTION_KEY=""
# Must be exactly 16 chars. Generate with: openssl rand -hex 8
ENCRYPTION_IV_SECRET=""

# --- Google Cloud ---
GCP_PROJECT_ID="YOUR_GCP_PROJECT_ID"
GCP_REGION="us-central1"
GCS_BUCKET_NAME="YOUR_GCS_BUCKET_NAME"
GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"

# --- Google Analytics (per store, also used globally) ---
GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
GA4_API_SECRET="YOUR_GA4_API_SECRET"

# --- Gemini AI ---
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-1.5-pro"

# --- Stripe (global default, stores can override) ---
STRIPE_SECRET_KEY="sk_test_XXXXXXXXXXXXXXXX"
STRIPE_WEBHOOK_SECRET="whsec_XXXXXXXXXXXXXXXX"

# --- Email (for notifications) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@email.com"
SMTP_PASS="YOUR_APP_PASSWORD"
EMAIL_FROM="noreply@yourdomain.com"

# --- Redis (for caching and real-time) ---
REDIS_URL="redis://localhost:6379"

# --- App URLs ---
API_URL="http://localhost:3001"
ADMIN_URL="http://localhost:3002"
STORE_URL="http://localhost:3003"
SUPER_ADMIN_URL="http://localhost:3004"

# --- CORS ---
ALLOWED_ORIGINS="http://localhost:3002,http://localhost:3003,http://localhost:3004"

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="100"

# --- Anomaly Detection ---
KL_DIVERGENCE_THRESHOLD="0.5"
METRIC_SNAPSHOT_INTERVAL_MS="60000"
BASELINE_WINDOW_HOURS="168"

# --- Data Retention ---
APP_LOGS_RETENTION_DAYS="30"
METRIC_SNAPSHOTS_RETENTION_DAYS="90"

# --- Super Admin ---
# Used by the seed script — never hardcode credentials in source code
SUPER_ADMIN_EMAIL="superadmin@yourdomain.com"
SUPER_ADMIN_PASSWORD=""
# Demo store seed credentials
DEMO_STORE_ADMIN_EMAIL="storeadmin@yourdomain.com"
DEMO_STORE_ADMIN_PASSWORD=""

# --- Cloud Logging ---
LOG_LEVEL="info"
STRUCTURED_LOGGING="true"
