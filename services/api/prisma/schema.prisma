// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== MULTI-TENANT STORE ====================

model Store {
  id           String           @id @default(cuid())
  slug         String           @unique
  name         String
  description  String?
  logoUrl      String?
  faviconUrl   String?
  theme        ThemeFramework   @default(TAILWIND)
  primaryColor String           @default("#6366f1")
  configured   Boolean          @default(false)
  gaId         String? // Google Analytics Measurement ID
  customDomain String?          @unique
  active       Boolean          @default(true)
  tier         SubscriptionTier @default(STARTER)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  users           User[]
  pages           Page[]
  products        Product[]
  orders          Order[]
  messages        ContactMessage[]
  tickets         SupportTicket[]
  chatSessions    ChatSession[]
  settings        StoreSettings?
  metricSnapshots MetricSnapshot[]
  logs            AppLog[]
  companies       Company[]
  priceLists      PriceList[]
  experiments     Experiment[]
  vendors         Vendor[]
  videoClips      VideoClip[]
  liveStreams     LiveStream[]
  apiKeys         ApiKey[]
  discounts       DiscountRule[]
  installations   AppInstallation[]
  roles           Role[]
  locations       Location[]

  @@index([slug])
}

enum SubscriptionTier {
  STARTER
  GROWTH
  ENTERPRISE
}

enum ThemeFramework {
  TAILWIND
  BOOTSTRAP
  BULMA
  PICO
}

model StoreSettings {
  id                  String   @id @default(cuid())
  storeId             String   @unique
  store               Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  stripePublicKey     String?
  stripeSecretKey     String? // AES-256 encrypted
  geminiApiKeyEnc     String? // AES-256 encrypted - store-specific override
  contactEmail        String?
  shippingPolicy      String?
  returnPolicy        String?
  privacyPolicy       String?
  aboutText           String?
  metaTitle           String?
  metaDescription     String?
  currency            String   @default("USD")
  taxRate             Float    @default(0) // legacy fallback
  taxNexus            String[] @default([]) // e.g., ["CA", "NY"]
  freeShippingAbove   Float?
  flatShippingRate    Float    @default(0)
  gaId                String?
  supplierWebhookUrls String[] @default([])
}

// ==================== USERS & AUTH ====================

model User {
  id          String    @id @default(cuid())
  email       String
  password    String // bcrypt hashed
  name        String
  avatarUrl   String?
  roleId      String
  role        Role      @relation(fields: [roleId], references: [id])
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id])
  tags        String[]  @default([])
  active      Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  replies        MessageReply[]
  ticketComments TicketComment[]
  refreshTokens  RefreshToken[]

  @@unique([email, storeId])
  @@index([storeId])
}

// ==================== ROLES & PERMISSIONS ====================

model Role {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isStatic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions Permission[]

  @@unique([storeId, name])
  @@index([storeId])
}

model Permission {
  id        String   @id @default(cuid())
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  action    String
  createdAt DateTime @default(now())

  @@unique([roleId, action])
  @@index([roleId])
}

// ==================== API KEYS (EDGE API) ====================

model ApiKey {
  id         String    @id @default(cuid())
  storeId    String
  store      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name       String
  key        String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([storeId])
  @@index([key])
}

model SuperAdmin {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String // bcrypt hashed
  name          String
  active        Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id           String      @id @default(cuid())
  token        String      @unique
  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  superAdminId String?
  superAdmin   SuperAdmin? @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime    @default(now())
}

// ==================== PAGES & BUILDER ====================

model Page {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  type      PageType @default(CUSTOM)
  slug      String
  title     String
  layout    Json     @default("[]") // Array of PageComponent JSON
  seoTitle  String?
  seoDesc   String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, slug])
  @@index([storeId])
}

enum PageType {
  LANDING
  PRODUCTS
  PRODUCT_DETAIL
  CART
  CHECKOUT
  CONFIRMATION
  CONTACT
  ABOUT
  CUSTOM
}

// ==================== PRODUCTS & INVENTORY ====================

model Product {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  vendorId     String?
  vendor       Vendor?  @relation(fields: [vendorId], references: [id])
  sku          String?
  name         String
  description  String?
  price        Decimal  @db.Decimal(10, 2)
  comparePrice Decimal? @db.Decimal(10, 2)
  stock        Int      @default(0)
  trackStock   Boolean  @default(true)
  category     String?
  tags         String[]
  images       String[] // GCS URLs
  variants     Json? // [{name: "Size", options: ["S","M","L"]}]
  modelUrl     String? // 3D model GLTF/USDZ URL
  arEnabled    Boolean  @default(false)
  weight       Float?
  length       Float?
  width        Float?
  height       Float?
  active       Boolean  @default(true)
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orderItems OrderItem[]
  videoClips VideoClip[]
  stocks     Stock[]

  @@index([storeId])
  @@index([storeId, category])
  @@index([storeId, active])
}

// ==================== INVENTORY LOCATIONS ====================

model Location {
  id         String   @id @default(cuid())
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name       String
  addressEnc String? // Encrypted JSON
  priority   Int      @default(0) // Higher value = higher priority for fulfillment
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  stocks     Stock[]
  orderItems OrderItem[]

  @@index([storeId])
}

model Stock {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  quantity   Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([productId, locationId])
  @@index([productId])
  @@index([locationId])
}

// ==================== ORDERS (Customer PII is encrypted) ====================

model Order {
  id               String      @id @default(cuid())
  storeId          String
  store            Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  vendorId         String? // For sub-orders assigned to a specific vendor
  vendor           Vendor?     @relation(fields: [vendorId], references: [id])
  parentOrderId    String? // If this is a split sub-order
  parentOrder      Order?      @relation("SplitOrders", fields: [parentOrderId], references: [id])
  subOrders        Order[]     @relation("SplitOrders")
  orderNumber      String      @unique // Human-readable: ORD-2024-0001
  status           OrderStatus @default(PENDING)
  // PII encrypted with AES-256 - key per store
  customerEmailEnc String // encrypted
  customerNameEnc  String // encrypted
  customerPhoneEnc String? // encrypted
  shippingAddrEnc  String // encrypted JSON
  // Non-PII financial data
  subtotal         Decimal     @db.Decimal(10, 2)
  totalDiscount    Decimal     @default(0) @db.Decimal(10, 2)
  appliedDiscounts Json? // Array of { ruleId: string, code: string, amount: number }
  tax              Decimal     @default(0) @db.Decimal(10, 2)
  shipping         Decimal     @default(0) @db.Decimal(10, 2)
  carrier          String?
  shippingService  String?
  total            Decimal     @db.Decimal(10, 2)
  currency         String      @default("USD")
  stripePaymentId  String?
  stripeSessionId  String?
  companyId        String?
  company          Company?    @relation(fields: [companyId], references: [id])
  paymentTerms     String? // e.g. "Net-30"
  notes            String?
  trackingNumber   String?
  shippedAt        DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  items OrderItem[]

  @@index([storeId])
  @@index([storeId, status])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id             String    @id @default(cuid())
  orderId        String
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendorId       String? // Link to vendor for the item
  vendor         Vendor?   @relation(fields: [vendorId], references: [id])
  productId      String
  product        Product   @relation(fields: [productId], references: [id])
  productName    String // Snapshot at time of purchase
  quantity       Int
  price          Decimal   @db.Decimal(10, 2)
  discountAmount Decimal   @default(0) @db.Decimal(10, 2)
  discountRuleId String?
  variantInfo    Json? // Snapshot of variant selection
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])
}

// ==================== MESSAGES ====================

model ContactMessage {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  // PII encrypted
  nameEnc   String
  emailEnc  String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  replies MessageReply[]

  @@index([storeId])
  @@index([storeId, read])
}

model MessageReply {
  id        String         @id @default(cuid())
  messageId String
  message   ContactMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  body      String
  sentAt    DateTime       @default(now())
}

// ==================== SUPPORT TICKETS ====================

model SupportTicket {
  id           String         @id @default(cuid())
  storeId      String
  store        Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  ticketNumber String         @unique // TKT-0001
  title        String
  description  String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  category     String?
  kanbanOrder  Int            @default(0)
  resolvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  comments TicketComment[]

  @@index([storeId])
  @@index([status])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_INFO
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model TicketComment {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String? // null = super admin
  user      User?         @relation(fields: [userId], references: [id])
  body      String
  internal  Boolean       @default(false) // true = only visible to super admin
  createdAt DateTime      @default(now())
}

// ==================== AI CHAT ====================

model ChatSession {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  visitorId String // Anonymous or customer ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([storeId])
}

model ChatMessage {
  id            String      @id @default(cuid())
  sessionId     String
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role          ChatRole
  content       String
  actionType    String? // e.g., "PRODUCT_RECOMMENDATION", "ADD_TO_CART"
  actionPayload Json?
  createdAt     DateTime    @default(now())
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

// ==================== MONITORING & ANOMALY DETECTION ====================

model MetricSnapshot {
  id        String   @id @default(cuid())
  storeId   String? // null = global platform metric
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  metric    String // e.g., "error_rate", "response_time_p99", "order_count"
  value     Float
  tags      Json? // Additional labels
  timestamp DateTime @default(now())

  @@index([storeId, metric, timestamp])
  @@index([metric, timestamp])
}

model AlertRule {
  id            String    @id @default(cuid())
  metric        String
  threshold     Float // KL divergence threshold
  windowMinutes Int       @default(5)
  baselineHours Int       @default(168) // 7 days
  enabled       Boolean   @default(true)
  notifyEmail   String?
  lastFiredAt   DateTime?
  createdAt     DateTime  @default(now())
}

model Alert {
  id           String        @id @default(cuid())
  ruleId       String?
  metric       String
  storeId      String?
  severity     AlertSeverity @default(WARNING)
  message      String
  klDivergence Float?
  acknowledged Boolean       @default(false)
  createdAt    DateTime      @default(now())

  @@index([acknowledged, createdAt])
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// ==================== LOGGING ====================

model AppLog {
  id        String   @id @default(cuid())
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  level     LogLevel
  service   String // "api", "admin", "store"
  message   String
  meta      Json? // Non-PII metadata
  traceId   String?
  timestamp DateTime @default(now())

  @@index([storeId, timestamp])
  @@index([level, timestamp])
  @@index([service, timestamp])
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  CRITICAL
}

// ==================== B2B & WHOLESALE ====================

model Company {
  id          String     @id @default(cuid())
  storeId     String
  store       Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  taxId       String?
  creditLimit Decimal?   @db.Decimal(10, 2)
  users       User[]
  orders      Order[]
  priceListId String?
  priceList   PriceList? @relation(fields: [priceListId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([storeId])
}

model PriceList {
  id          String    @id @default(cuid())
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  description String?
  prices      Json      @default("{}") // productId -> overriddenPrice mapping
  companies   Company[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([storeId])
}

// ==================== A/B TESTING ====================

model Experiment {
  id        String           @id @default(cuid())
  storeId   String
  store     Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  status    ExperimentStatus @default(DRAFT)
  variants  Variant[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([storeId])
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

model Variant {
  id           String     @id @default(cuid())
  experimentId String
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  name         String
  weight       Int        @default(50) // Traffic percentage
  layout       Json // Overrides page layout
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// ==================== LIVE COMMERCE ====================

model VideoClip {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  url          String // GCS URL
  thumbnailUrl String?
  duration     Int? // seconds
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products Product[]

  @@index([storeId])
  @@index([storeId, active])
}

model LiveStream {
  id           String           @id @default(cuid())
  storeId      String
  store        Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  status       LiveStreamStatus @default(PENDING)
  url          String? // GCS or external stream URL
  thumbnailUrl String?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([storeId])
  @@index([storeId, status])
}

enum LiveStreamStatus {
  PENDING
  LIVE
  ENDED
}

model Vendor {
  id                 String   @id @default(cuid())
  storeId            String
  store              Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  logoUrl            String?
  stripeAccountIdEnc String? // Store Stripe Connect Account ID encrypted
  payoutEnabled      Boolean  @default(false)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  products   Product[]
  orders     Order[]
  orderItems OrderItem[]

  @@index([storeId])
}

// ==================== 3RD-PARTY PUBLIC APP API ====================

model ExternalApp {
  id           String   @id @default(cuid())
  name         String
  description  String?
  developerId  String? // Optional link to a user who owns the app
  clientId     String   @unique
  clientSecret String // AES-256 encrypted
  redirectUris String[] // Allowed OAuth redirect URIs
  webhookUrl   String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  installations AppInstallation[]
  webhooks      WebhookSubscription[]
  authCodes     OAuthCode[]

  @@index([clientId])
}

model AppInstallation {
  id              String      @id @default(cuid())
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  appId           String
  app             ExternalApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  // OAuth2 Tokens (AES-256 encrypted)
  accessTokenEnc  String
  refreshTokenEnc String?
  scopes          String[] // e.g., ["read_products", "write_orders"]
  expiresAt       DateTime?
  installedAt     DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([storeId, appId])
  @@index([storeId])
  @@index([appId])
}

model WebhookSubscription {
  id        String      @id @default(cuid())
  appId     String
  app       ExternalApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  storeId   String
  // Relation to Store is already implicit via AppInstallation, but we can make it explicit if needed.
  // For simplicity, we just store the storeId.
  topic     String // e.g., "products/create", "orders/paid"
  targetUrl String
  secret    String // AES-256 encrypted for signature verification
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())

  @@index([appId, storeId])
}

model OAuthCode {
  id        String      @id @default(cuid())
  code      String      @unique
  appId     String
  app       ExternalApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  storeId   String
  userId    String // User who authorized the app
  scopes    String[]
  expiresAt DateTime
  createdAt DateTime    @default(now())

  @@index([code])
}

// ==================== DISCOUNTS ====================

model DiscountRule {
  id          String       @id @default(cuid())
  storeId     String
  store       Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  code        String? // Optional code for manual entry
  description String?
  type        DiscountType
  value       Decimal      @db.Decimal(10, 2)
  priority    Int          @default(0)
  combinable  Boolean      @default(false)
  active      Boolean      @default(true)
  startDate   DateTime?
  endDate     DateTime?

  // For Buy X Get Y
  buyQuantity  Int?
  getQuantity  Int?
  buyProductId String?
  getProductId String?

  conditions DiscountCondition[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([storeId])
  @@index([code])
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  BUY_X_GET_Y
}

model DiscountCondition {
  id        String        @id @default(cuid())
  ruleId    String
  rule      DiscountRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  type      ConditionType
  value     String // e.g., "100.00" for MIN_CART_VALUE, or "VIP" for CUSTOMER_TAG
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum ConditionType {
  MIN_CART_VALUE
  CUSTOMER_TAG
}
